<nav class="navbar navbar-expand-md navbar-dark bg-dark px-3 navbar-custom">

  <!-- LEFT: LOGO -->
  <%= link_to "Kevin Stal",
              root_path(locale: I18n.locale),
              class: "navbar-brand logo-font" %>

  <!-- RIGHT TOP BAR GROUP -->
  <div class="navbar-top-right">

    <!-- LANGUAGE -->
    <div class="lang-switcher">
      <% [:de, :en, :nl].each do |lang| %>
        <%= link_to url_for(locale: lang),
            class: "lang-link #{'active' if I18n.locale == lang}" do %>

          <span class="lang-mobile-flag">
            <%= {de: "🇩🇪", en: "🇬🇧", nl: "🇳🇱"}[lang] %>
          </span>

          <span class="lang-desktop"><%= lang.to_s.upcase %></span>

        <% end %>
      <% end %>
    </div>

    <!-- HAMBURGER -->
    <button class="navbar-toggler custom-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNav">

      <span></span>
      <span></span>
      <span></span>

    </button>

  </div>

  <!-- COLLAPSIBLE MENU -->
  <div class="collapse navbar-collapse" id="navbarNav">

    <ul class="navbar-nav nav-links">

      <li class="nav-item">
        <%= link_to t("nav.home"), root_path(locale: I18n.locale),
          class: "nav-link nav-underline js-nav-link active" %>
      </li>

      <li class="nav-item">
        <a class="nav-link nav-underline js-nav-link" href="#about">
          <%= t("nav.about") %>
        </a>
      </li>

      <li class="nav-item">
        <a class="nav-link nav-underline js-nav-link" href="#contact">
          <%= t("nav.contact") %>
        </a>
      </li>

    </ul>

  </div>

</nav>