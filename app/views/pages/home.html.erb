<div class="container py-5 hero-content">

  <div class="hero-grid">

    <!-- LEFT -->
    <div class="hero-left">
      <h1 class="fw-bold">
        <%= t("home.hero.title") %>
      </h1>

      <p class="text-muted my-4 hero-text">
        <%= t("home.hero.subtitle") %>
      </p>

      <h4 class="mb-3 mt-5">
        <%= t("home.sections.what_i_can_build") %>
      </h4>

      <ul class="ps-3">
        <li class="mb-2"><%= t("home.building.static_sites") %></li>
        <li class="mb-2"><%= t("home.building.auth_apps") %></li>
        <li class="mb-2"><%= t("home.building.database_apps") %></li>
        <li class="mb-2"><%= t("home.building.frontend") %></li>
        <li class="mb-2"><%= t("home.building.backend") %></li>
        <li class="mb-2"><%= t("home.building.multilingual") %></li>
      </ul>
    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      <div class="contact-box">

        <h5 class="mb-4">
          <%= t("home.sections.tech_stack") %>
        </h5>

        <div class="mb-4">
          <h6 class="fw-bold mb-2"><%= t("home.tech.frontend") %></h6>
          <p class="mb-0">
            HTML5, CSS, SCSS,<br>
            JavaScript, AJAX, Vue.js
          </p>
        </div>

        <div class="mb-4">
          <h6 class="fw-bold mb-2"><%= t("home.tech.backend") %></h6>
          <p class="mb-0">
            Ruby, Ruby on Rails, PostgreSQL<br>
            Devise, ActiveRecord, REST APIs
          </p>
        </div>

        <div class="mb-4">
          <h6 class="fw-bold mb-2"><%= t("home.tech.tools") %></h6>
          <p class="mb-0">
            GitHub, Heroku, Render
          </p>
        </div>

        <h5 class="mb-3 mt-5">
          <%= t("home.sections.languages") %>
        </h5>

        <p class="mb-1"><%= t("home.sections.dutch") %></p>
        <p class="mb-1"><%= t("home.sections.german") %></p>
        <p class="mb-1"><%= t("home.sections.english") %></p>

        <p class="mt-4 text-muted">
          <%= t("home.location") %>
        </p>

      </div>
    </div>

  </div>
</div>